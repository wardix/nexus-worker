# Environment Configuration
NODE_ENV=development

# NATS Configuration
NATS_URL=nats://localhost:4222
NATS_STREAM_NAME=NEXUS_STREAM
NATS_CONSUMER_NAME=nexus_worker_group

# NATS Authentication (Optional)
# NATS_USER=my_user
# NATS_PASS=my_password
# NATS_TOKEN=my_token

# Zabbix iForte Configuration
IFORTE_ZABBIX_URL=https://zabbix.iforte.id/api_jsonrpc.php
IFORTE_ZABBIX_USERNAME=your_username
IFORTE_ZABBIX_PASSWORD=your_password
IFORTE_ZABBIX_GRAPH_NAME_FILTER=NUSANET-
IFORTE_GRAPH_ID_PREFIX=iforte-

# NIS Sync Configuration
NIS_GRAPH_SYNC_URL=https://api.nusa.net.id/v1/sync/graphs
NIS_TOKEN=your_nis_token
